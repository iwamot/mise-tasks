{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>iwamot/renovate-config#v0.11.0",
    "docker:disable"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track aqua tools declared in mise file tasks (#MISE tools={...})",
      "managerFilePatterns": [
        "/(^|/)\\.mise/tasks/[^/]+$/"
      ],
      "matchStrings": [
        "\"aqua:(?<depName>[^\"]+)\"\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ]
}
